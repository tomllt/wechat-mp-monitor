# ============================================
# WeChat MP Monitor 配置文件
# ============================================

# 代理模式:
#   - none: 不使用代理
#   - content: 仅文章正文下载走代理（推荐）
#   - all: 所有请求走代理
PROXY_MODE=content

# 下载并发数，建议 3-10，过高容易触发风控
DOWNLOAD_CONCURRENCY=3

# 私有 Worker 代理列表（英文逗号分隔）
# 不配置则使用内置公共代理
# WORKER_PROXIES=https://proxy1.example.com,https://proxy2.example.com

# 文章存储根目录
# 不配置则使用: ~/wechat-articles
# STORAGE_ROOT=/path/to/your/articles
